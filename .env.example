# Database (MySQL 8.0+)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=wanye

# API Server
PORT=8080
JWT_SECRET=change-me-in-production
JWT_EXPIRY=24h

# SMTP (leave empty to log tokens to stdout)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Google OAuth (leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# Frontend
FRONTEND_URL=http://localhost:3000

# Frontend (runtime, injected at container start)
API_URL=http://localhost:8080

# ========== Server deploy (docker-compose.server.yml) ==========
# 与同机 grapery 错开端口：grapery 用 3000/8080，ideaevo 默认用 3001/8090
# IDEAEVO_API_PORT=8090
# IDEAEVO_WEB_PORT=3001
# IDEAEVO_PUBLIC_API_URL=https://www.ideavalues.xyz
# IDEAEVO_API_MEM_LIMIT=128m
# IDEAEVO_WEB_MEM_LIMIT=384m
# IDEAEVO_NODE_OPTIONS=--max-old-space-size=320

# LLM (leave LLM_API_KEY empty for mock responses)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# System Agent (optional, ID of the default assistant agent)
# 留空时启动会自动创建一个名为「万叶助手」的内置 agent 作为页面聊天默认对象
SYSTEM_AGENT_ID=

# ========== Vector Search (Aliyun OSS Vector Bucket) ==========
# 留空时降级到 MySQL LIKE 模糊匹配（精度较低，仅作兜底）。
# 启用步骤：
#   1. 在阿里云 OSS 控制台创建「向量 Bucket」(名字不同于普通 OSS bucket)
#   2. 在该 bucket 内创建索引：名为 ideas，维度 1024，度量 cosine
#   3. 在 RAM 控制台创建 AccessKey（建议用 RAM 子账号，授予该向量 Bucket 读写权限）
#   4. 把以下变量填好后重启服务，启动日志会打印 [vector] enabled
#
# 认证说明：与 grapery 项目共用同一套阿里云主账号；
#          这里直接用 AccessKey 服务端调用（不走 STS，因为不需要客户端直传）。
# ALIYUN_OSS_ACCESS_KEY_ID=
# ALIYUN_OSS_ACCESS_KEY_SECRET=
# ALIYUN_VECTOR_BUCKET=ideaevo-vectors-dev   # 向量 bucket 名（独立于普通 OSS）
# ALIYUN_VECTOR_REGION=cn-shanghai            # 和 grapery OSS 同 region
# ALIYUN_VECTOR_ACCOUNT_ID=                   # 阿里云主账号 ID（向量签名必需，控制台头像处可见）
# VECTOR_INDEX_IDEAS=ideas                    # 向量索引名（需先在控制台创建）

# ========== Embedding (Aliyun DashScope / 百炼) ==========
# 用通义 text-embedding-v3，OpenAI 兼容接口。
# 国内访问快，无需翻墙；与向量 bucket 维度需保持一致（默认 1024）。
# 申请：https://bailian.console.aliyun.com/ → Api-Key 管理
# DASHSCOPE_API_KEY=
# EMBEDDING_MODEL=text-embedding-v3
# EMBEDDING_DIMENSIONS=1024

# ========== WeChat Open Platform (网站应用扫码) ==========
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=
# WECHAT_REDIRECT_URL=http://localhost:8080/api/auth/wechat/callback

# ========== Aliyun OSS user assets (普通 bucket，非向量 bucket) ==========
# 复用 ALIYUN_OSS_ACCESS_KEY_ID / ALIYUN_OSS_ACCESS_KEY_SECRET
# ALIYUN_ASSETS_BUCKET=
# ALIYUN_ASSETS_REGION=cn-shanghai
# ALIYUN_ASSETS_CDN_DOMAIN=
# 部署提示：Bucket 需配置 CORS 允许浏览器 PUT；头像/背景需公共读或走 CDN 域名

# ========== Aliyun SMS (手机验证码) ==========
# 可复用 OSS AccessKey；未配置时 OTP 打印到 stdout（开发模式）
# ALIYUN_SMS_SIGN_NAME=
# ALIYUN_SMS_TEMPLATE_CODE=
