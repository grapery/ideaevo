# Database (MySQL 8.0+)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=wanye

# API Server
PORT=8080
JWT_SECRET=change-me-in-production
JWT_EXPIRY=24h

# SMTP (leave empty to log tokens to stdout)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Google OAuth (leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# Frontend
FRONTEND_URL=http://localhost:3000

# Frontend (runtime, injected at container start)
API_URL=http://localhost:8080

# ========== Server deploy (docker-compose.server.yml) ==========
# 与同机 grapery 错开端口：grapery 用 3000/8080，ideaevo 默认用 3001/8090
# IDEAEVO_API_PORT=8090
# IDEAEVO_WEB_PORT=3001
# IDEAEVO_PUBLIC_API_URL=https://www.ideavalues.xyz
# IDEAEVO_API_MEM_LIMIT=128m
# IDEAEVO_WEB_MEM_LIMIT=384m
# IDEAEVO_NODE_OPTIONS=--max-old-space-size=320

# LLM 对话 — 留空则 Mock 回复
#
# 本地测试（火山方舟，与 grapery 对齐）:
#   HUOSHAN_API_KEY=方舟 API Key（控制台 → API Key 管理）
#   HUOSHAN_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
#   HUOSHAN_TEXT_MODEL=ep-xxxxxxxx   # 推理接入点 ID，强烈建议配置
#   勿同时设置 LLM_API_KEY（优先级更高，会覆盖火山）
#
# HUOSHAN_CLOUD_KEY / HUOSHAN_CLOUD_SECRET 为火山云 AK/SK，ideaevo 对话 LLM 不使用；
# 与 grapery 一样，聊天走 HUOSHAN_API_KEY + 官方 arkruntime SDK。
#
# 线上部署：GitHub Actions 从仓库 vars 注入 HUOSHAN_API_KEY / HUOSHAN_BASE_URL / HUOSHAN_TEXT_MODEL
# （见 .github/workflows/api-ci.yml，与 grapery server-ci 共用同名 vars）
LLM_API_KEY=
# HUOSHAN_API_KEY=
# HUOSHAN_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# HUOSHAN_TEXT_MODEL=ep-xxxxxxxxxx-xxxxx
LLM_BASE_URL=https://api.openai.com/v1
# 未设 HUOSHAN_TEXT_MODEL 时默认 doubao-seed-2-0-lite-260215；自定义接入点请设 ep-xxx
LLM_MODEL=gpt-4o

# System Agent (optional, ID of the default assistant agent)
# 留空时启动会自动创建一个名为「万叶助手」的内置 agent 作为页面聊天默认对象
SYSTEM_AGENT_ID=

# ========== Vector Search ==========
# 推荐：百炼 DashVector（VECTOR_BACKEND=dashvector）
# 备选：OSS 向量 Bucket（VECTOR_BACKEND=oss）
#
# --- DashVector（推荐）---
# 在百炼控制台创建 Cluster，获取 Endpoint；Collection 需预先创建（默认 ideas，1536 维 cosine）
# VECTOR_BACKEND=dashvector
# DASHVECTOR_ENDPOINT=https://vrs-cn-xxxx.dashvector.cn-hangzhou.aliyuncs.com
# DASHVECTOR_METRIC=cosine
# DASHSCOPE_API_KEY=                    # embedding + DashVector 鉴权共用
# VECTOR_INDEX_IDEAS=ideas              # Collection 名称
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_DIMENSIONS=1536
#
# --- OSS 向量 Bucket（遗留，可选）---
# 鉴权：ALIYUN_OSS_ACCESS_KEY_ID → ALIYUN_ACCESS_KEY_ID → ALIYUN_SMS_ACCESS_KEY_ID
# VECTOR_BACKEND=oss
# ALIYUN_VECTOR_BUCKET=ideaevo-vectors-prod
# ALIYUN_VECTOR_REGION=cn-shanghai
# ALIYUN_VECTOR_ACCOUNT_ID=1866841989078847

# ========== WeChat Open Platform (网站应用扫码) ==========
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=
# WECHAT_REDIRECT_URL=http://localhost:8080/api/auth/wechat/callback

# ========== Aliyun OSS user assets (普通 bucket，非向量 bucket) ==========
# 复用上方同一套 AccessKey（见鉴权优先级说明）
# ALIYUN_ASSETS_BUCKET=ideaevo
# ALIYUN_ASSETS_REGION=cn-shanghai
# ALIYUN_ASSETS_CDN_DOMAIN=                    # 可选；留空则用 https://ideaevo.oss-cn-shanghai.aliyuncs.com
# 部署提示：Bucket 需配置 CORS 允许浏览器 PUT；头像/背景需公共读或走 CDN 域名

# ========== Aliyun SMS (手机验证码，与 grapery 变量名一致) ==========
# 签名/模板未配置时使用代码默认值（上海秩量科技 / SMS_333971751）
# ALIYUN_SMS_SIGN_NAME=
# ALIYUN_SMS_TEMPLATE_CODE=
# ALIYUN_SMS_REGION=cn-hangzhou
# ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
# 凭证（按优先级）：SMS 专用 Key → 通用 Aliyun Key → OSS Key → ECS RAM 角色链
# ALIYUN_SMS_ACCESS_KEY_ID=          # CI: vars.ALIYUN_SMS_ACCESS_ID
# ALIYUN_SMS_ACCESS_KEY_SECRET=      # CI: vars.ALIYUN_SMS_ACCESS_SECRET
# ALIYUN_SMS_USE_DEFAULT_CREDENTIAL=1  # ECS 部署时与 grapery 一致，启用 RAM 凭证链
# 未配置任何凭证时 OTP 打印到 stdout（开发模式）
